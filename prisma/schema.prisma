// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/* ENUMS */
enum Gender {
  MALE
  FEMALE
  OTHER
}
/* GENERAL */
model Country{
  id String @id
  name String @unique
}
/* APP */
model Person {
  id String @id
  username String @unique
  name String
  lastname String
  email String
  phone String?
  image String?
  gender Gender

}